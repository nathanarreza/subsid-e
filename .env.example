# ── GEMINI API KEY ROTATION ──────────────────────────────────────────────────
# Add up to 10 Gemini API keys. The server rotates through them automatically.
# Keys are tried round-robin and fall to the next on 429/503 rate limit errors.
# Get free keys at: https://aistudio.google.com/app/apikey
# At minimum, GEMINI_KEY_1 must be set. All others are optional.

GEMINI_KEY_1=AIza...
GEMINI_KEY_2=AIza...
GEMINI_KEY_3=AIza...
GEMINI_KEY_4=AIza...
GEMINI_KEY_5=AIza...
GEMINI_KEY_6=AIza...
GEMINI_KEY_7=AIza...
GEMINI_KEY_8=AIza...
GEMINI_KEY_9=AIza...
GEMINI_KEY_10=AIza...

# ── MODEL CONFIGURATION ───────────────────────────────────────────────────────
# Primary model for chat and generation. Gemma 3 1B is fast and free-tier friendly.
# Options: gemma-3-1b-it | gemma-3-4b-it | gemma-3-12b-it | gemma-3-27b-it
#          gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_MODEL=gemma-3-1b-it

# Model for news grounding (Google Search grounding requires a Gemini model).
# Gemma models do not support grounding. Set this to a gemini-* model for live news.
GEMINI_GROUNDING_MODEL=gemini-2.0-flash

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Max tokens for chat responses
CHAT_MAX_TOKENS=800
# Max tokens for news responses
NEWS_MAX_TOKENS=2000
# Request timeout in milliseconds
API_TIMEOUT_MS=20000
